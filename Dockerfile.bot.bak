# Railway Bot Dockerfile
# Multi-stage build for sync-erp Bot (WhatsApp) service

FROM node:22-slim AS builder

# Build args for Prisma generate
ARG DATABASE_URL
ENV DATABASE_URL=$DATABASE_URL

WORKDIR /app

# Install dependencies needed for native modules
RUN apt-get update -y && apt-get install -y python3 make g++ openssl ca-certificates curl

# Copy all source code
COPY . .

# Install all dependencies
RUN npm ci --include=dev

# Generate Prisma client with patch script (bot may need database types)
WORKDIR /app/packages/database
RUN npx prisma generate && node ../scripts/patch-zod-types.mjs
WORKDIR /app

# Build bot and its dependencies using turbo
RUN npx turbo run build --filter=@sync-erp/bot...

# Production stage
FROM node:22-slim AS production

WORKDIR /app

# Install openssl for Prisma runtime AND ca-certificates for HTTPS
RUN apt-get update -y && apt-get install -y openssl ca-certificates

# Copy package files and node_modules
COPY --from=builder /app/package*.json ./
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/apps/bot ./apps/bot
COPY --from=builder /app/packages/database ./packages/database
COPY --from=builder /app/packages/shared ./packages/shared

# Set environment
ENV NODE_ENV=production
ENV SYNC_ERP_API_URL=https://sync-erp-api-production.up.railway.app/api/trpc
ENV NODE_OPTIONS="--dns-result-order=ipv4first"
ENV SYNC_ERP_API_KEY=dev_bot_secret_key_2026

# Set PRISMA_CONFIG_FILE for any runtime prisma calls
ENV PRISMA_CONFIG_FILE=packages/database/prisma.config.ts

# Start bot service
CMD ["node", "apps/bot/dist/index.js"]
