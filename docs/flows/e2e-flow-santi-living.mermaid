    classDef pageNavigate stroke:#2962FF, fill:#cbe5fa, color:#000000, stroke-width:4px, stroke-dasharray:5
    classDef userEvent stroke:#00C853, fill:#C8E6C9, color:#2962FF, stroke:#000000, stroke-width:2px, stroke-dasharray:0
    classDef user fill:#e1f5fe, stroke:#01579b, stroke-width:2px
    classDef system fill:#fff3e0, stroke:#e65100, stroke-width:2px, stroke-dasharray:5 5
    classDef Admin stroke:#AA00FF, fill:#E1BEE7, color:#000000
    classDef adminEvent stroke:#000000, fill:#AA00FF, color:#FFFFFF
    classDef endNode fill:#ffebee, stroke:#b71c1c, stroke-width:2px
    classDef storedData fill:#eeeeee, stroke:#616161, stroke-width:1px, stroke-dasharray:2 2
    classDef diam shape:diamond,fill:#fff3e0,stroke:#e65100,stroke-width:2px