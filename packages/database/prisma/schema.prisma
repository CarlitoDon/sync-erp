// Sync ERP MVP - Prisma Schema
// Based on: specs/001-sync-erp-mvp/data-model.md

generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Core Models
// ============================================

model Company {
  id            String        @id @default(uuid())
  name          String
  businessShape BusinessShape @default(PENDING)
  inviteCode    String?       @unique @default(cuid())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  members         CompanyMember[]
  partners        Partner[]
  products        Product[]
  orders          Order[]
  movements       InventoryMovement[]
  invoices        Invoice[]
  payments        Payment[]
  journals        JournalEntry[]
  accounts        Account[]
  roles           Role[]
  configs         SystemConfig[]
  warehouses      Warehouse[]
  categories      ProductCategory[]
  idempotencyKeys IdempotencyKey[]
  sagaLogs        SagaLog[]
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companies CompanyMember[]
  sessions  Session[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model CompanyMember {
  id        String   @id @default(uuid())
  userId    String
  companyId String
  roleId    String?
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role    Role?   @relation(fields: [roleId], references: [id])

  @@unique([userId, companyId])
  @@index([companyId])
}

// ============================================
// Master Data
// ============================================

model Partner {
  id        String      @id @default(uuid())
  companyId String
  type      PartnerType
  name      String
  email     String?
  phone     String?
  address   String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  orders   Order[]
  invoices Invoice[]

  @@index([companyId])
  @@index([companyId, type])
}

model Product {
  id            String        @id @default(uuid())
  companyId     String
  categoryId    String?
  sku           String
  name          String
  price         Decimal       @db.Decimal(15, 2)
  averageCost   Decimal       @default(0) @db.Decimal(15, 2)
  stockQty      Int           @default(0)
  unitOfMeasure String        @default("PCS")
  costingMethod CostingMethod @default(AVG)
  isService     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  company     Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category    ProductCategory?    @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  movements   InventoryMovement[]
  stockLayers StockLayer[]

  @@unique([companyId, sku])
  @@index([companyId])
  @@index([categoryId])
}

// ============================================
// Transactions (Orders)
// ============================================

model Order {
  id          String      @id @default(uuid())
  companyId   String
  partnerId   String
  type        OrderType
  status      OrderStatus @default(DRAFT)
  orderNumber String?
  date        DateTime    @default(now())
  totalAmount Decimal     @db.Decimal(15, 2)
  taxRate     Decimal     @default(0) @db.Decimal(5, 2)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  company  Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  partner  Partner     @relation(fields: [partnerId], references: [id])
  items    OrderItem[]
  invoices Invoice[]

  @@index([companyId])
  @@index([companyId, type])
  @@index([companyId, status])
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Decimal  @db.Decimal(15, 2)
  cost      Decimal? @db.Decimal(15, 2) // COGS snapshot at time of shipment

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}

// ============================================
// Inventory
// ============================================

model InventoryMovement {
  id          String       @id @default(uuid())
  companyId   String
  productId   String
  warehouseId String?
  type        MovementType
  quantity    Int
  reference   String?
  date        DateTime     @default(now())
  createdAt   DateTime     @default(now())

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product   Product    @relation(fields: [productId], references: [id])
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])

  @@index([companyId])
  @@index([productId])
  @@index([warehouseId])
  @@index([companyId, productId])
}

// ============================================
// Finance
// ============================================

model Invoice {
  id            String        @id @default(uuid())
  companyId     String
  orderId       String?
  partnerId     String
  type          InvoiceType
  status        InvoiceStatus @default(DRAFT)
  invoiceNumber String?
  dueDate       DateTime
  amount        Decimal       @db.Decimal(15, 2) // Total
  subtotal      Decimal       @default(0) @db.Decimal(15, 2)
  taxAmount     Decimal       @default(0) @db.Decimal(15, 2)
  taxRate       Decimal       @default(0) @db.Decimal(5, 2)
  balance       Decimal       @db.Decimal(15, 2)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  order    Order?    @relation(fields: [orderId], references: [id])
  partner  Partner   @relation(fields: [partnerId], references: [id])
  payments Payment[]

  relatedInvoiceId String?
  relatedInvoice   Invoice?  @relation("CreditNotes", fields: [relatedInvoiceId], references: [id])
  creditNotes      Invoice[] @relation("CreditNotes")

  @@index([companyId])
  @@index([companyId, type])
  @@index([companyId, status])
}

model Payment {
  id        String   @id @default(uuid())
  companyId String
  invoiceId String
  amount    Decimal  @db.Decimal(15, 2)
  date      DateTime @default(now())
  method    String
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([companyId])
  @@index([invoiceId])
}

// Chart of Accounts
model Account {
  id        String      @id @default(uuid())
  companyId String
  code      String // e.g., "1100", "2100", "4100"
  name      String // e.g., "Cash", "Accounts Payable", "Sales Revenue"
  type      AccountType
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  journalLines JournalLine[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, type])
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum JournalSourceType {
  INVOICE
  BILL
  PAYMENT
  CREDIT_NOTE
  ADJUSTMENT
}

model JournalEntry {
  id         String             @id @default(uuid())
  companyId  String
  reference  String?
  date       DateTime
  memo       String?
  sourceType JournalSourceType? // Source document type (nullable for backward compat)
  sourceId   String? // Source document ID (nullable for backward compat)
  createdAt  DateTime           @default(now())

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines   JournalLine[]

  @@unique([companyId, sourceType, sourceId]) // Prevent double-posting
  @@index([companyId])
}

model JournalLine {
  id        String  @id @default(uuid())
  journalId String
  accountId String
  debit     Decimal @default(0) @db.Decimal(15, 2)
  credit    Decimal @default(0) @db.Decimal(15, 2)

  journal JournalEntry @relation(fields: [journalId], references: [id], onDelete: Cascade)
  account Account      @relation(fields: [accountId], references: [id])

  @@index([journalId])
  @@index([accountId])
}

// ============================================
// Access Control (RBAC)
// ============================================

model Role {
  id        String   @id @default(uuid())
  companyId String
  name      String
  createdAt DateTime @default(now())

  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  members     CompanyMember[]
  permissions RolePermission[]

  @@unique([companyId, name])
  @@index([companyId])
}

model Permission {
  id     String @id @default(uuid())
  module String
  action String
  scope  String @default("ALL")

  roles RolePermission[]

  @@unique([module, action, scope])
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

// ============================================
// Enums
// ============================================

enum PartnerType {
  CUSTOMER
  SUPPLIER
}

enum OrderType {
  SALES
  PURCHASE
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum MovementType {
  IN
  OUT
}

enum InvoiceType {
  INVOICE
  BILL
  CREDIT_NOTE
}

enum InvoiceStatus {
  DRAFT
  POSTED
  PAID
  VOID
}

// ============================================
// Apple-Like Core Enums
// ============================================

enum BusinessShape {
  PENDING
  RETAIL
  MANUFACTURING
  SERVICE
}

enum CostingMethod {
  AVG
  FIFO
}

// ============================================
// System Configuration
// ============================================

model SystemConfig {
  id        String   @id @default(uuid())
  companyId String
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, key])
  @@index([companyId])
}

// ============================================
// Warehouse
// ============================================

model Warehouse {
  id        String   @id @default(uuid())
  companyId String
  code      String
  name      String
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company     Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  movements   InventoryMovement[]
  stockLayers StockLayer[]

  @@unique([companyId, code])
  @@index([companyId])
}

// ============================================
// Product Category
// ============================================

model ProductCategory {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  description String?
  createdAt   DateTime @default(now())

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([companyId])
}

// ============================================
// Stock Layer (Future FIFO Support)
// ============================================

model StockLayer {
  id           String   @id @default(uuid())
  productId    String
  warehouseId  String
  qtyRemaining Int
  unitCost     Decimal  @db.Decimal(15, 2)
  receivedAt   DateTime
  createdAt    DateTime @default(now())

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([warehouseId])
  @@index([warehouseId, receivedAt])
}

// ============================================
// Infrastructure (Idempotency)
// ============================================

model IdempotencyKey {
  id        String            @id // Uniquely generated by client (UUID usually)
  companyId String
  scope     IdempotencyScope
  entityId  String? // Entity this key is scoped to (nullable for backward compat)
  status    IdempotencyStatus
  response  Json?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt // For zombie lock detection

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, scope, entityId]) // Prevent same operation on same entity
  @@index([companyId])
  @@index([status, updatedAt]) // For efficient zombie cleanup query
}

enum IdempotencyScope {
  INVOICE_POST
  PAYMENT_CREATE
  // Add more as needed
}

enum IdempotencyStatus {
  PROCESSING
  COMPLETED
  FAILED
}

// ============================================
// SAGA Transaction Tracking
// ============================================

model SagaLog {
  id        String   @id @default(uuid())
  sagaType  SagaType
  entityId  String
  companyId String
  step      SagaStep
  stepData  Json?
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@index([companyId, sagaType, step])
}

enum SagaType {
  INVOICE_POST
  SHIPMENT
  GOODS_RECEIPT
  BILL_POST
  PAYMENT_POST
  CREDIT_NOTE
  STOCK_TRANSFER
  STOCK_RETURN
}

enum SagaStep {
  PENDING
  STOCK_DONE
  BALANCE_DONE
  JOURNAL_DONE
  COMPLETED
  FAILED
  COMPENSATION_FAILED
}
