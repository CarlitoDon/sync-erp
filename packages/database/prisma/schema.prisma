// Sync ERP MVP - Prisma Schema
// Based on: specs/001-sync-erp-mvp/data-model.md

generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

generator zod {
  provider             = "zod-prisma-types"
  output               = "../../shared/src/generated/zod"
  useDefaultValidators = false
  createInputTypes     = false
  prismaClientPath     = "@sync-erp/database/client"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Core Models
// ============================================

model Company {
  id            String        @id @default(uuid())
  name          String
  businessShape BusinessShape @default(PENDING)
  inviteCode    String?       @unique @default(cuid())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  members           CompanyMember[]
  partners          Partner[]
  products          Product[]
  orders            Order[]
  movements         InventoryMovement[]
  invoices          Invoice[]
  payments          Payment[]
  journals          JournalEntry[]
  accounts          Account[]
  roles             Role[]
  configs           SystemConfig[]
  warehouses        Warehouse[]
  categories        ProductCategory[]
  idempotencyKeys   IdempotencyKey[]
  sagaLogs          SagaLog[]
  auditLogs         AuditLog[]
  documentSequences DocumentSequence[]
  fulfillments      Fulfillment[]
  bankAccounts      BankAccount[]
  cashTransactions  CashTransaction[]
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companies CompanyMember[]
  sessions  Session[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model CompanyMember {
  id        String   @id @default(uuid())
  userId    String
  companyId String
  roleId    String?
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role    Role?   @relation(fields: [roleId], references: [id])

  @@unique([userId, companyId])
  @@index([companyId])
}

// ============================================
// Master Data
// ============================================

model Partner {
  id        String      @id @default(uuid())
  companyId String
  type      PartnerType
  name      String
  email     String?
  phone     String?
  address   String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  orders   Order[]
  invoices Invoice[]

  @@index([companyId])
  @@index([companyId, type])
}

model Product {
  id            String        @id @default(uuid())
  companyId     String
  categoryId    String?
  sku           String
  name          String
  price         Decimal       @db.Decimal(15, 2)
  averageCost   Decimal       @default(0) @db.Decimal(15, 2)
  stockQty      Int           @default(0)
  unitOfMeasure String        @default("PCS")
  costingMethod CostingMethod @default(AVG)
  isService     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  company          Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category         ProductCategory?    @relation(fields: [categoryId], references: [id])
  orderItems       OrderItem[]
  movements        InventoryMovement[]
  stockLayers      StockLayer[]
  fulfillmentItems FulfillmentItem[]
  invoiceItems     InvoiceItem[]

  @@unique([companyId, sku])
  @@index([companyId])
  @@index([categoryId])
}

// ============================================
// Transactions (Orders)
// ============================================

model Order {
  id            String         @id @default(uuid())
  companyId     String
  partnerId     String
  type          OrderType
  status        OrderStatus    @default(DRAFT)
  orderNumber   String?
  date          DateTime       @default(now())
  totalAmount   Decimal        @db.Decimal(15, 2)
  taxRate       Decimal        @default(0) @db.Decimal(5, 2)
  // Feature 036: Cash Upfront Payment
  paymentTerms  PaymentTerms   @default(NET_30)
  paymentStatus PaymentStatus?
  paidAmount    Decimal        @default(0) @db.Decimal(15, 2)
  // Feature: Down Payment (Partial)
  dpPercent     Decimal?       @db.Decimal(5, 2) // 0-100%
  dpAmount      Decimal?       @db.Decimal(15, 2) // Auto-calculated from percent or manual
  notes         String? // P2P: Notes
  version       Int            @default(1) // Optimistic Locking
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  partner            Partner             @relation(fields: [partnerId], references: [id])
  items              OrderItem[]
  invoices           Invoice[]
  upfrontPayments    Payment[]           @relation("OrderUpfrontPayments") // Feature 036
  fulfillments       Fulfillment[]
  inventoryMovements InventoryMovement[]

  @@index([companyId])
  @@index([companyId, type])
  @@index([companyId, status])
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Decimal  @db.Decimal(15, 2)
  cost      Decimal? @db.Decimal(15, 2) // COGS snapshot at time of shipment

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  fulfillmentItems FulfillmentItem[]

  @@index([orderId])
}

// ============================================
// Inventory
// ============================================

model InventoryMovement {
  id            String       @id @default(uuid())
  companyId     String
  productId     String
  warehouseId   String?
  orderId       String? // FK to Order (PO/SO)
  fulfillmentId String? // FK to Fulfillment (GRN/Shipment)
  type          MovementType
  quantity      Int
  reference     String?
  date          DateTime     @default(now())
  createdAt     DateTime     @default(now())

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product     Product      @relation(fields: [productId], references: [id])
  warehouse   Warehouse?   @relation(fields: [warehouseId], references: [id])
  order       Order?       @relation(fields: [orderId], references: [id])
  fulfillment Fulfillment? @relation(fields: [fulfillmentId], references: [id])

  @@index([companyId])
  @@index([productId])
  @@index([warehouseId])
  @@index([companyId, productId])
  @@index([orderId])
  @@index([fulfillmentId])
}

// ============================================
// Finance
// ============================================

model Invoice {
  id                    String        @id @default(uuid())
  companyId             String
  orderId               String?
  partnerId             String
  type                  InvoiceType
  status                InvoiceStatus @default(DRAFT)
  invoiceNumber         String?
  dueDate               DateTime
  amount                Decimal       @db.Decimal(15, 2) // Total
  subtotal              Decimal       @default(0) @db.Decimal(15, 2)
  taxAmount             Decimal       @default(0) @db.Decimal(15, 2)
  taxRate               Decimal       @default(0) @db.Decimal(5, 2)
  balance               Decimal       @db.Decimal(15, 2)
  supplierInvoiceNumber String? // P2P: External Bill Ref
  paymentTermsString    String? // P2P: Terms
  notes                 String? // P2P: Notes
  version               Int           @default(1) // Optimistic Locking
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  order    Order?    @relation(fields: [orderId], references: [id])
  partner  Partner   @relation(fields: [partnerId], references: [id])
  payments Payment[]

  relatedInvoiceId String?
  relatedInvoice   Invoice?      @relation("CreditNotes", fields: [relatedInvoiceId], references: [id])
  creditNotes      Invoice[]     @relation("CreditNotes")
  items            InvoiceItem[]

  // Feature: Explicit DP Linking
  isDownPayment Boolean   @default(false)
  dpBillId      String?
  dpBill        Invoice?  @relation("DpBills", fields: [dpBillId], references: [id])
  finalBills    Invoice[] @relation("DpBills")

  // Feature 041: Fulfillment Linking (GRN for Bills, Shipment for Invoices)
  fulfillmentId String?
  fulfillment   Fulfillment? @relation("FulfillmentInvoices", fields: [fulfillmentId], references: [id])

  @@index([companyId])
  @@index([companyId, type])
  @@index([companyId, status])
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  productId   String?
  description String?
  quantity    Int     @default(1)
  price       Decimal @db.Decimal(15, 2)
  amount      Decimal @db.Decimal(15, 2)

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([invoiceId])
  @@index([productId])
}

model Payment {
  id               String        @id @default(uuid())
  companyId        String
  invoiceId        String? // Made optional: for invoice/bill payments
  // Feature 036: Cash Upfront Payment
  orderId          String? // For upfront payments (PO link)
  paymentType      String        @default("INVOICE") // 'UPFRONT' | 'INVOICE'
  settledAt        DateTime? // When this prepaid was applied to bill
  settlementBillId String? // Which bill consumed this prepaid
  amount           Decimal       @db.Decimal(15, 2)
  date             DateTime      @default(now())
  method           PaymentMethod
  reference        String? // P2P: External Ref
  accountId        String? // P2P: Bank/Cash Account
  version          Int           @default(1) // Optimistic Locking
  createdAt        DateTime      @default(now())

  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice Invoice? @relation(fields: [invoiceId], references: [id])
  order   Order?   @relation("OrderUpfrontPayments", fields: [orderId], references: [id])

  @@index([companyId])
  @@index([invoiceId])
  @@index([orderId])
  @@index([paymentType])
}

// Chart of Accounts
model Account {
  id        String      @id @default(uuid())
  companyId String
  parentId  String? // Parent account for hierarchy (e.g., sub-accounts under 1200 Bank)
  code      String // e.g., "1100", "1201", "4100"
  name      String // e.g., "Cash", "BCA Checking", "Sales Revenue"
  type      AccountType
  isGroup   Boolean     @default(false) // True for parent accounts (Cash, Bank)
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  company              Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent               Account?              @relation("AccountHierarchy", fields: [parentId], references: [id])
  children             Account[]             @relation("AccountHierarchy")
  journalLines         JournalLine[]
  bankAccounts         BankAccount[]
  cashTransactionItems CashTransactionItem[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, type])
  @@index([parentId])
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum JournalSourceType {
  INVOICE
  BILL
  PAYMENT
  CREDIT_NOTE
  ADJUSTMENT
  CASH_TRANSACTION
}

model JournalEntry {
  id         String             @id @default(uuid())
  companyId  String
  reference  String?
  date       DateTime
  memo       String?
  sourceType JournalSourceType? // Source document type (nullable for backward compat)
  sourceId   String? // Source document ID (nullable for backward compat)
  createdAt  DateTime           @default(now())

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines           JournalLine[]
  cashTransaction CashTransaction?

  @@unique([companyId, sourceType, sourceId]) // Prevent double-posting
  @@index([companyId])
}

model JournalLine {
  id        String  @id @default(uuid())
  journalId String
  accountId String
  debit     Decimal @default(0) @db.Decimal(15, 2)
  credit    Decimal @default(0) @db.Decimal(15, 2)

  journal JournalEntry @relation(fields: [journalId], references: [id], onDelete: Cascade)
  account Account      @relation(fields: [accountId], references: [id])

  @@index([journalId])
  @@index([accountId])
}

// ============================================
// Access Control (RBAC)
// ============================================

model Role {
  id        String   @id @default(uuid())
  companyId String
  name      String
  createdAt DateTime @default(now())

  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  members     CompanyMember[]
  permissions RolePermission[]

  @@unique([companyId, name])
  @@index([companyId])
}

model Permission {
  id     String           @id @default(uuid())
  module PermissionModule
  action PermissionAction
  scope  PermissionScope  @default(ALL)

  roles RolePermission[]

  @@unique([module, action, scope])
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

// ============================================
// Enums
// ============================================

// Permission Enums (FR-026: Granular RBAC)
enum PermissionModule {
  COMPANY
  SALES
  PURCHASING
  INVENTORY
  FINANCE
  USERS
}

enum PermissionAction {
  CREATE
  READ
  UPDATE
  DELETE
  APPROVE
  VOID
}

enum PermissionScope {
  ALL
  OWN
}

enum PartnerType {
  CUSTOMER
  SUPPLIER
}

enum OrderType {
  SALES
  PURCHASE
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_RECEIVED
  RECEIVED
  PARTIALLY_SHIPPED
  SHIPPED
  COMPLETED
  CANCELLED
}

enum MovementType {
  IN
  OUT
}

enum InvoiceType {
  INVOICE
  BILL
  EXPENSE
  CREDIT_NOTE
  DEBIT_NOTE // P2P: Buyer claims credit from supplier (reduces AP)
}

enum InvoiceStatus {
  DRAFT
  POSTED
  PARTIALLY_PAID
  PAID
  VOID
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CREDIT_CARD
  CHECK
  OTHER
}

// ============================================
// Apple-Like Core Enums
// ============================================

enum BusinessShape {
  PENDING
  RETAIL
  MANUFACTURING
  SERVICE
}

enum CostingMethod {
  AVG
  FIFO
}

// Feature 036: Cash Upfront Payment
enum PaymentTerms {
  NET7
  NET30
  NET60
  NET90
  COD
  EOM
  NET_30 // Legacy
  UPFRONT // Full payment before delivery
}

enum PaymentStatus {
  PENDING // Upfront PO, no payment yet
  PARTIAL // Some payment made
  PAID_UPFRONT // Fully paid upfront
  SETTLED // Prepaid cleared against bill
}

// GRN/Shipment Document Status
enum DocumentStatus {
  DRAFT
  POSTED
  VOIDED
}

// Fulfillment Type (unified model for GRN, Shipment, and Return)
enum FulfillmentType {
  RECEIPT // Goods Receipt (PO → Stock IN)
  SHIPMENT // Shipment (SO → Stock OUT)
  RETURN // Sales Return (SO → Stock IN, COGS reversal)
  PURCHASE_RETURN // Purchase Return (PO → Stock OUT, GRNI reversal)
}

// ============================================
// System Configuration
// ============================================

model SystemConfig {
  id        String   @id @default(uuid())
  companyId String
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

// ============================================
// Document Numbering
// ============================================

model DocumentSequence {
  id           String       @id @default(uuid())
  companyId    String
  type         SequenceType
  year         Int
  month        Int
  lastSequence Int          @default(0)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, type, year, month])
  @@index([companyId])
}

enum SequenceType {
  PO
  GRN
  SHP
  BILL
  PAY
  SO
  INV
  CN
  JE
  DN // Debit Note
  RET // Sales Return
  PRR // Purchase Return
}

// ============================================
// Warehouse
// ============================================

model Warehouse {
  id        String   @id @default(uuid())
  companyId String
  code      String
  name      String
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company     Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  movements   InventoryMovement[]
  stockLayers StockLayer[]

  @@unique([companyId, code])
  @@index([companyId])
}

// ============================================
// Product Category
// ============================================

model ProductCategory {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  description String?
  createdAt   DateTime @default(now())

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([companyId])
}

// ============================================
// Stock Layer (Future FIFO Support)
// ============================================

model StockLayer {
  id           String   @id @default(uuid())
  productId    String
  warehouseId  String
  qtyRemaining Int
  unitCost     Decimal  @db.Decimal(15, 2)
  receivedAt   DateTime
  createdAt    DateTime @default(now())

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([warehouseId])
  @@index([warehouseId, receivedAt])
}

// ============================================
// Infrastructure (Idempotency)
// ============================================

model IdempotencyKey {
  id        String            @id // Uniquely generated by client (UUID usually)
  companyId String
  scope     IdempotencyScope
  entityId  String? // Entity this key is scoped to (nullable for backward compat)
  status    IdempotencyStatus
  response  Json?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt // For zombie lock detection

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Note: id is already unique as PK. We removed @@unique([companyId, scope, entityId])
  // because it prevents multiple partial payments on the same invoice.
  @@index([companyId])
  @@index([companyId, scope, entityId]) // For efficient lookup
  @@index([status, updatedAt]) // For efficient zombie cleanup query
}

enum IdempotencyScope {
  INVOICE_POST
  PAYMENT_CREATE
  BILL_CREATE
  INVOICE_CREATE
  GRN_CREATE
  SHIPMENT_CREATE
  ORDER_CREATE
  CASH_TRANSACTION_POST
}

enum IdempotencyStatus {
  PROCESSING
  COMPLETED
  FAILED
}

// ============================================
// SAGA Transaction Tracking
// ============================================

model SagaLog {
  id            String   @id @default(uuid())
  sagaType      SagaType
  entityId      String
  companyId     String
  step          SagaStep
  stepData      Json?
  error         String?
  correlationId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@index([companyId, sagaType, step])
  @@index([correlationId])
}

model AuditLog {
  id              String         @id @default(uuid())
  companyId       String
  actorId         String
  action          AuditLogAction
  entityType      EntityType
  entityId        String
  businessDate    DateTime
  payloadSnapshot Json?
  correlationId   String?
  createdAt       DateTime       @default(now())

  company           Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  cashTransaction   CashTransaction? @relation(fields: [cashTransactionId], references: [id])
  cashTransactionId String?

  @@index([companyId, action])
  @@index([entityId])
  @@index([businessDate])
  @@index([correlationId])
}

enum AuditLogAction {
  INVOICE_POSTED
  INVOICE_VOIDED
  BILL_POSTED
  BILL_VOIDED
  PAYMENT_RECORDED
  ORDER_CREATED
  ORDER_CONFIRMED
  ORDER_CANCELLED
  GOODS_RECEIVED
  SHIPMENT_CREATED
  GRN_POSTED
  GRN_VOIDED
  SHIPMENT_VOIDED
  PAYMENT_VOIDED
  PRICE_VARIANCE_ACKNOWLEDGED // FR-051: Log acknowledged price variances
  CASH_TRANSACTION_POSTED
  CASH_TRANSACTION_VOIDED
}

enum EntityType {
  INVOICE
  BILL
  PAYMENT
  ORDER
  SHIPMENT
  GOODS_RECEIPT
  BANK_ACCOUNT
  CASH_TRANSACTION
}

enum SagaType {
  INVOICE_POST
  SHIPMENT
  GOODS_RECEIPT
  BILL_POST
  PAYMENT_POST
  CREDIT_NOTE
  STOCK_TRANSFER
  STOCK_RETURN
}

enum SagaStep {
  PENDING
  STOCK_DONE
  BALANCE_DONE
  JOURNAL_DONE
  COMPLETED
  FAILED
  COMPENSATION_FAILED
}

// ============================================
// Unified Fulfillment Model (replaces GoodsReceipt + Shipment)
// ============================================

model Fulfillment {
  id         String          @id @default(uuid())
  companyId  String
  orderId    String
  type       FulfillmentType
  number     String
  date       DateTime
  status     DocumentStatus  @default(DRAFT)
  notes      String?
  receivedBy String? // Only for RECEIPT type
  version    Int             @default(1)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  company Company           @relation(fields: [companyId], references: [id])
  order   Order             @relation(fields: [orderId], references: [id])
  items   FulfillmentItem[]

  // Feature 041: Invoices/Bills linked to this Fulfillment
  // - For RECEIPT (GRN): Bills (Invoice type=BILL)
  // - For SHIPMENT: Invoices (Invoice type=INVOICE)
  invoices           Invoice[]           @relation("FulfillmentInvoices")
  inventoryMovements InventoryMovement[]

  @@index([companyId])
  @@index([orderId])
  @@index([type])
}

model FulfillmentItem {
  id            String   @id @default(uuid())
  fulfillmentId String
  productId     String
  orderItemId   String
  quantity      Decimal  @db.Decimal(10, 2)
  costSnapshot  Decimal? @db.Decimal(15, 2) // Only for SHIPMENT (COGS)

  fulfillment Fulfillment @relation(fields: [fulfillmentId], references: [id])
  product     Product     @relation(fields: [productId], references: [id])
  orderItem   OrderItem   @relation(fields: [orderItemId], references: [id])
}

// ============================================
// Feature 042: Cash and Bank
// ============================================

model BankAccount {
  id            String   @id @default(uuid())
  companyId     String
  accountId     String // Link to GL Account
  bankName      String // e.g. "BCA", "Petty Cash"
  accountNumber String?
  currency      String   @default("IDR")
  isArchived    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id])

  // Relations
  outgoingTransactions CashTransaction[] @relation("SourceBank")
  incomingTransactions CashTransaction[] @relation("DestinationBank")

  @@unique([companyId, accountId])
  @@index([companyId])
}

model CashTransaction {
  id          String                @id @default(uuid())
  companyId   String
  type        CashTransactionType
  status      CashTransactionStatus @default(DRAFT)
  date        DateTime              @default(now())
  reference   String? // e.g. "INV-001", "Check #123"
  payee       String? // Name of person/company paid/received from
  description String?
  amount      Decimal               @db.Decimal(15, 2)

  // Links
  sourceBankAccountId      String? // For SPEND and TRANSFER
  destinationBankAccountId String? // For RECEIVE and TRANSFER

  journalEntryId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sourceBank      BankAccount?  @relation("SourceBank", fields: [sourceBankAccountId], references: [id])
  destinationBank BankAccount?  @relation("DestinationBank", fields: [destinationBankAccountId], references: [id])
  journalEntry    JournalEntry? @relation(fields: [journalEntryId], references: [id])

  items CashTransactionItem[] // Split lines for Spend/Receive

  auditLogs AuditLog[] // Relation for AuditLog

  @@index([companyId])
  @@index([companyId, type])
  @@index([date])
}

model CashTransactionItem {
  id                String  @id @default(uuid())
  cashTransactionId String
  accountId         String // The allocation account (Expense/Revenue/etc)
  description       String?
  amount            Decimal @db.Decimal(15, 2) // Always positive, direction determined by Parent Type

  transaction CashTransaction @relation(fields: [cashTransactionId], references: [id], onDelete: Cascade)
  account     Account         @relation(fields: [accountId], references: [id])

  @@index([cashTransactionId])
}

enum CashTransactionType {
  SPEND
  RECEIVE
  TRANSFER
}

enum CashTransactionStatus {
  DRAFT
  POSTED
  VOIDED
}
