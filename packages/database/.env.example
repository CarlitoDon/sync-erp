# PostgreSQL Database Connection
# ================================
# Used by all services via @sync-erp/database package

# Connection string untuk PostgreSQL database
# Format: postgresql://user:password@host:port/database?schema=public
# Local development example:
DATABASE_URL="postgresql://postgres:password@localhost:5432/sync_erp?schema=public"

# Production (Railway):
# DATABASE_URL akan otomatis di-set oleh Railway platform
# Jangan copy-paste; biarkan Railway manage ini via dashboard

# NODE_ENV untuk menentukan environment
# Aplikasi akan membaca .env atau .env.test sesuai NODE_ENV
NODE_ENV=development
