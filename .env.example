# Environment Configuration Example
# Copy this file to .env for development or .env.production for production

# Node Environment
NODE_ENV="development"

# PostgreSQL Database Connection
DATABASE_URL="postgresql://user:password@localhost:5432/sync-erp?schema=public"

# Seed Configuration
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="secure_password"

# Santi Living Webhook Config
SANTI_LIVING_WEBHOOK_URL="http://localhost:3002"
SANTI_LIVING_WEBHOOK_API_KEY="santi_rental_secret_2026"

# API Configuration
SYNC_ERP_API_URL="http://localhost:3001/api/trpc"

# Auth Configuration
# BOT_SECRET is required for service-to-service authentication
BOT_SECRET="dev_bot_secret_key_2026"
