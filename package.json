{
  "name": "sync-erp",
  "version": "0.0.1",
  "private": true,
  "description": "Sync ERP - Multi-Company ERP System",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev --workspace=@sync-erp/api",
    "dev:web": "npm run dev --workspace=@sync-erp/web",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "npm run db:generate --workspace=@sync-erp/database",
    "db:push": "npm run db:push --workspace=@sync-erp/database",
    "db:migrate": "npm run db:migrate --workspace=@sync-erp/database",
    "db:seed": "npm run db:seed --workspace=@sync-erp/database",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.53.3",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "turbo": "^2.3.3",
    "typescript": "^5.3.3"
  }
}
