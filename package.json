{
  "name": "sync-erp",
  "version": "0.0.1",
  "private": true,
  "description": "Sync ERP - Multi-Company ERP System",
  "packageManager": "npm@11.6.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev --workspace=@sync-erp/api",
    "dev:web": "npm run dev --workspace=@sync-erp/web",
    "typecheck": "tsc -b",
    "typecheck:watch": "tsc -b --watch",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "test:all": "turbo run test:all",
    "db:reset": "npm run db:reset --workspace=@sync-erp/database",
    "db:generate": "npm run db:generate --workspace=@sync-erp/database",
    "db:push": "npm run db:push --workspace=@sync-erp/database",
    "db:migrate": "npm run db:migrate --workspace=@sync-erp/database",
    "db:seed": "npm run db:seed --workspace=@sync-erp/database",
    "db:studio": "npm run db:studio --workspace=@sync-erp/database",
    "db:test": "npm run db:test --workspace=@sync-erp/database",
    "db:reseed:full": "npm run db:reset && npm run db:seed && ./scripts/seed-via-api.sh",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@sync-erp/eslint-plugin": "file:packages/eslint-plugin",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.2.0",
    "turbo": "^2.6.3",
    "typescript": "^5.9.3"
  }
}
