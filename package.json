{
  "name": "sync-erp",
  "version": "0.0.1",
  "private": true,
  "description": "Sync ERP - Multi-Company ERP System",
  "packageManager": "npm@11.6.1",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently --kill-others -n \"api,web,bot\" -c \"red,blue,green\" \"npm run dev --workspace=@sync-erp/api\" \"npm run dev --workspace=@sync-erp/web\" \"npm run dev --workspace=@sync-erp/bot\"",

    "build": "turbo run build",
    "build:api": "turbo run build --filter=@sync-erp/api",
    "build:web": "turbo run build --filter=@sync-erp/web",
    "build:bot": "turbo run build --filter=@sync-erp/bot",

    "postinstall": "if [ -z \"$DATABASE_URL\" ]; then echo 'Skipping db:generate (DATABASE_URL not set)'; else npm run db:generate --workspace=@sync-erp/database; fi",

    "typecheck": "tsc -b",
    "typecheck:watch": "tsc -b --watch",

    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "test:all": "turbo run test:all",

    "db:reset": "npm run db:reset --workspace=@sync-erp/database",
    "db:generate": "npm run db:generate --workspace=@sync-erp/database",
    "db:push": "npm run db:push --workspace=@sync-erp/database",
    "db:migrate": "npm run db:migrate --workspace=@sync-erp/database",
    "db:seed": "npm run db:seed --workspace=@sync-erp/database",
    "db:seed:dev": "NODE_ENV=development npm run db:seed --workspace=@sync-erp/database",
    "db:seed:prod": "NODE_ENV=production npm run db:seed --workspace=@sync-erp/database",
    "db:studio": "npm run db:studio --workspace=@sync-erp/database",
    "db:test": "npm run db:test --workspace=@sync-erp/database",

    "db:reseed:full": "npm run db:reset && npm run db:seed && ./scripts/seed-via-api.sh",

    "knip": "export $(cat packages/database/.env | xargs) && knip",

    "clean": "turbo run clean && rm -rf node_modules"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@sync-erp/eslint-plugin": "file:packages/eslint-plugin",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "knip": "^5.0.0",
    "prettier": "^3.2.0",
    "turbo": "^2.6.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "qrcode.react": "^4.2.0"
  }
}
