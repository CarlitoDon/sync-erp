# Production Environment for Bot
NODE_ENV="production"
PORT=3010

# API Connection
SYNC_ERP_API_URL="https://your-api-service.up.railway.app/api/trpc"
BOT_SECRET="your_bot_secret"

# Internal/Local Auth
API_KEY="your_api_key"
API_SECRET="your_api_secret"

# Redis (Update with actual production Redis URL if different)
REDIS_URL="redis://default:password@redis.railway.internal:6379"
