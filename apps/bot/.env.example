# Sync ERP Bot Service Environment
# ==================================
# WhatsApp bot service untuk kirim notifikasi & update order status

# Server Configuration
PORT=3010
NODE_ENV=development

# API Connection (CRITICAL)
# URL ke sync-erp API backend
SYNC_ERP_API_URL=http://localhost:3001/api/trpc

# Authentication (CRITICAL)
# Shared secret untuk authenticate dengan sync-erp API
# WAJIB SAMA dengan BOT_SECRET di sync-erp/apps/api
BOT_SECRET=dev_bot_secret_key_2026

# Data Persistence (CRITICAL untuk production)
# Redis URL untuk menyimpan WhatsApp session state (Baileys)
# Format: redis://[:password@]host:port[/db]
REDIS_URL=redis://localhost:6379

# Optional: Legacy API Key (DEPRECATED - gunakan BOT_SECRET)
# Fallback jika BOT_SECRET tidak set (backward compatibility only)
SYNC_ERP_API_KEY=dev_bot_secret_key_2026

# Optional: Admin WhatsApp Number
# Nomor untuk test message & notifications
ADMIN_PHONE=6281234567890
