# Example Environment for Bot
# Copy this file to .env, .env.staging, or .env.production
NODE_ENV=development
PORT=3010

# ========================================
# Authentication
# ========================================

# Auth for Bot service (callers authenticate with this)
SYNC_ERP_BOT_SECRET=your_sync_erp_bot_secret

# ========================================
# Service Connections
# ========================================

# sync-erp API
SYNC_ERP_API_URL=https://api.santiliving.com/api/trpc
SYNC_ERP_API_SECRET=your_sync_erp_api_secret

# Redis
REDIS_URL=redis://localhost:6379
# Prefix for Redis keys (isolates prod/staging on shared Redis)
REDIS_KEY_PREFIX=baileys:auth:
