# Production Environment for Web
# Loaded by Vite at build time

# API URL (Railway Production)
VITE_API_URL="https://your-api-service.up.railway.app"
SYNC_ERP_API_URL="https://your-api-service.up.railway.app"

# Auth Keys (Public/Client-Safe)
# NOTE: These will be bundled into client code. Ensure safety.
API_KEY="your_api_key"
BOT_SECRET="your_bot_secret"

# Other Configurations
NODE_ENV="production"
