{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "jsx": "react-jsx",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@sync-erp/api": ["../api/src/index.ts"],
      "@sync-erp/database": ["../../packages/database/src/index.ts"],
      "@sync-erp/shared": ["../../packages/shared/src/index.ts"]
    },
    "types": ["vitest/globals", "@testing-library/jest-dom"],
    "module": "ESNext",
    "moduleResolution": "Bundler"
  },
  "include": ["src/**/*", "vite.config.ts", "test/**/*"],
  "exclude": ["node_modules", "dist"]
}
