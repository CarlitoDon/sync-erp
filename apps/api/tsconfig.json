{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "composite": false,
    "baseUrl": ".",
    "paths": {
      "@modules/*": ["./src/modules/*"],
      "@src/*": ["./src/*"],
      "@middlewares/*": ["./src/middlewares/*"],
      "@/*": ["./src/*"],
      "@routes/*": ["./src/routes/*"],
      "@sync-erp/database": ["../../packages/database/src"],
      "@sync-erp/shared": ["../../packages/shared/src"]
    },
    "outDir": "dist"
  },
  "include": ["src/**/*", "test/**/*"],
  "exclude": ["node_modules", "dist"]
}
