# Sync ERP API Environment
# =========================
# Main tRPC API backend

# Server Configuration
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Authentication (CRITICAL)
# Shared secret for service-to-service communication
# Must be set in production via Railway dashboard
BOT_SECRET=dev_bot_secret_key_2026

# Santi Living Webhook Integration
# Optional: webhook URL to notify santi-living of rental updates
SANTI_LIVING_WEBHOOK_URL=http://localhost:3002/api/webhooks/erp
# API key for webhook authentication (must match API_KEY in santi-living)
SANTI_LIVING_WEBHOOK_API_KEY=erp_sync_secret_2026

# Database Connection
# See packages/database/.env for DATABASE_URL configuration
# DATABASE_URL is loaded from @sync-erp/database package
