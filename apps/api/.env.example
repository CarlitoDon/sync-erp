# Production Environment for API
NODE_ENV="production"


# Webhook Integration (My Proxy Service)
SANTI_LIVING_WEBHOOK_URL="https://your-proxy-service.up.railway.app/api/webhooks/erp"
SANTI_LIVING_WEBHOOK_API_KEY="your_webhook_api_key"

# Auth
BOT_SECRET="your_bot_secret"

# CORS (Allow both Vercel and Custom Domain)
CORS_ORIGIN="http://localhost:5173,https://santiliving.com,https://santi-living.vercel.app,https://sync-erp.vercel.app"

# Production - Supabase Cloud (Singapore)
DATABASE_URL="postgresql://user:password@host:port/postgres"

# Internal/Local Auth
API_KEY="your_api_key"

# Public API URL (Self Reference for TRPC)
SYNC_ERP_API_URL="https://your-api-service.up.railway.app/api/trpc"
