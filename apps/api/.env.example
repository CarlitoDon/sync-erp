# Example Environment for API
# Copy this file to .env, .env.staging, or .env.production
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@host:port/database"

# ========================================
# Authentication Secrets
# ========================================

# Auth for API (services calling this API)
SYNC_ERP_API_SECRET=your_sync_erp_api_secret

# ========================================
# Service URLs
# ========================================

# Public API URL (Self Reference for TRPC)
SYNC_ERP_API_URL=https://api.santiliving.com/api/trpc

# ========================================
# CORS
# ========================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-domain.com

# ========================================
# Webhooks (Santi Living Integration)
# ========================================
SANTI_LIVING_WEBHOOK_URL=https://proxy.santiliving.com
SANTI_LIVING_WEBHOOK_API_KEY=your_santi_webhook_secret
